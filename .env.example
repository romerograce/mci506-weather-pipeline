# Carpeta local donde se guardan los archivos extraídos
OUTPUT_DIR=./output

# Días hacia atrás que incluye cada extracción
PAST_DAYS=2

# Días de pronóstico a incluir
FORECAST_DAYS=1

# Nombre del bucket de Google Cloud Storage
GCS_BUCKET_NAME=tu-bucket-aqui

# Ruta de la llave de la service account (solo para correr local)
GOOGLE_APPLICATION_CREDENTIALS=./keys/service_account.json
